    "apis": [
      {
        "id": "open_meteo",
        "name": "Open-Meteo",
        "base_url": "https://api.open-meteo.com/v1",
        "auth_required": false,
        "endpoints": [
          {
            "path": "/weather/open-meteo",
            "method": "GET",
            "summary": "Get current weather and forecast",
            "direct_url": "https://api.open-meteo.com/v1/forecast",
            "parameters": [
              {
                "name": "latitude",
                "type": "query",
                "required": true,
                "description": "Latitude coordinate"
              },
              {
                "name": "longitude",
                "type": "query",
                "required": true,
                "description": "Longitude coordinate"
              },
              {
                "name": "current_weather",
                "type": "query",
                "default": "true",
                "description": "Include current weather data"
              }
            ],
            "tags": ["weather", "forecast", "current-weather", "temperature"]
          }
        }
      ]
    }
  ]
