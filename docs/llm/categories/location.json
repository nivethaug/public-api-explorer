{
  "category": "location",
  "name": "Maps & Location",
  "description": "Geolocation, geocoding, and geographic data",
  "prefix": "/location",
  "apis": [
    {
      "id": "rest_countries",
      "name": "REST Countries",
      "base_url": "https://restcountries.com/v3.1",
      "auth_required": false,
      "endpoints": [
        {
          "path": "/location/countries",
          "method": "GET",
          "summary": "List all countries",
          "direct_url": "https://restcountries.com/v3.1/all",
          "parameters": [
            {"name": "name", "type": "query", "description": "Filter by country name"},
            {"name": "region", "type": "query", "description": "Filter by region"}
          ],
          "sample_request": "https://restcountries.com/v3.1/name/united",
          "sample_response": [
            {
              "name": {
                "common": "United States",
                "official": "United States of America",
                "nativeName": {
                  "eng": {
                    "official": "United States of America",
                    "common": "United States"
                  }
                }
              },
              "tld": [".us"],
              "cca2": "US",
              "ccn3": "840",
              "cca3": "USA",
              "cioc": "USA",
              "independent": true,
              "status": "officially-assigned",
              "unMember": true,
              "currencies": {
                "USD": {
                  "name": "United States dollar",
                  "symbol": "$"
                }
              },
              "capital": ["Washington, D.C."],
              "region": "Americas",
              "subregion": "North America",
              "population": 331002651,
              "area": 9833520.0,
              "latlng": [38.0, -97.0],
              "flag": "🇺🇸"
            }
          ]
        },
        {
          "path": "/location/countries/{code}",
          "method": "GET",
          "summary": "Get country by code",
          "direct_url": "https://restcountries.com/v3.1/alpha/{code}",
          "parameters": [
            {"name": "code", "type": "path", "description": "Country code (ISO 3166-1)"}
          ],
          "sample_request": "https://restcountries.com/v3.1/alpha/US",
          "sample_response": {
            "name": {"common": "United States", "official": "United States of America"},
            "capital": ["Washington, D.C."],
            "region": "Americas",
            "population": 331002651
          }
        }
      ]
    },
    {
      "id": "ip_api",
      "name": "IP-API",
      "base_url": "http://ip-api.com",
      "auth_required": false,
      "endpoints": [
        {
          "path": "/location/ip",
          "method": "GET",
          "summary": "Get IP geolocation",
          "direct_url": "http://ip-api.com/json/{ip}",
          "parameters": [
            {"name": "ip", "type": "query", "description": "IP address"}
          ],
          "sample_request": "http://ip-api.com/json/8.8.8.8",
          "sample_response": {
            "status": "success",
            "country": "United States",
            "countryCode": "US",
            "region": "CA",
            "regionName": "California",
            "city": "Mountain View",
            "zip": "94035",
            "lat": 37.386,
            "lon": -122.0838,
            "timezone": "America/Los_Angeles",
            "isp": "Google LLC",
            "org": "Google LLC",
            "as": "AS15169 Google LLC",
            "query": "8.8.8.8"
          }
        }
      ]
    }
  ],
  "use_cases": [
    "Get country information",
    "Lookup coordinates to addresses",
    "Get geolocation from IP",
    "Find user location",
    "Geographic filtering"
  ]
}
